@host = http://localhost:8080

@username = Buffalo
@password = Buffalo1234
@email = buffalo@admin.com

### Create Admin for testing
POST {{host}}/api/v1/auth/admins
Content-Type: application/json

{
    "username": "{{username}}",
    "email": "{{email}}",
    "password": "{{password}}",
    "mascotId": 1,
    "bio": "I got nothing to say"
}

### Login the Admin
POST {{host}}/api/v1/auth/login
Content-Type: application/json

{
    "usernameOrEmail": "{{username}}",
    "password": "{{password}}"
}

> {%
    client.global.set("adminAccessToken", response.body.accessToken.token);
%}

### Create Mascot
POST {{host}}/api/v1/mascots
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "mascotName": "Bird",
  "mascotImgUrl": "https://birdphoto.com/bird"
}

> {%
    client.global.set("mascot_id", response.body.mascotId);
%}

### Delete Mascot
DELETE {{host}}/api/v1/mascots/{{mascot_id}}
Authorization: Bearer {{adminAccessToken}}

### Delete Admin
DELETE {{host}}/api/v1/users/me
Authorization: Bearer {{adminAccessToken}}
