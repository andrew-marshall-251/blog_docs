@host = http://localhost:8080
@post_id = 1

@username = Commenter3000
@email = comment@comment.com
@password = Comment1234

### Create User
POST {{host}}/api/users
Content-Type: application/json

{
  "username": "{{username}}",
  "email": "{{email}}",
  "password": "{{password}}",
  "mascotId": 1,
  "bio" : "This is my bio"
}

### Login Commentor
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "usernameOrEmail": "{{username}}",
  "password": "{{password}}"
}

> {%
    client.global.set("userAccessToken", response.body.accessToken.token);
%}

### Create Comment
POST {{host}}/api/posts/{{post_id}}/comments
Authorization: Bearer {{userAccessToken}}
Content-Type: application/json

{
  "commentBody": "What a great post!!",
  "parentId": null
}

> {%
    client.global.set("comment_id", response.body.commentId);
%}

### Delete Comment
DELETE {{host}}/api/comments/{{comment_id}}
Authorization: Bearer {{userAccessToken}}

### Delete User
DELETE {{host}}/api/users/me
Authorization: Bearer {{userAccessToken}}
